        android:name="com.ilyadev.meowmoments.presentation.ui.detail.FactDetailFragment"
        android:label="FactDetailFragment"
        tools:layout="@layout/fragment_fact_detail">
        <argument
            android:name="fact"
            app:argType="com.ilyadev.meowmoments.domain.model.CatFact"
